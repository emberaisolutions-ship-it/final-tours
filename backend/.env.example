# Server Configuration
PORT=5000

# CORS Configuration (comma-separated list of allowed origins)
# Example: http://localhost:3000,https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# RapidAPI Configuration (get from https://rapidapi.com/)
RAPID_API_KEY=your_rapid_api_key_here

# Google APIs (get from https://console.cloud.google.com/)
GOOGLE_API_KEY=your_google_api_key_here
SEARCH_ENGINE_ID=your_search_engine_id_here

# Translation API (optional - for increased limits)
MYMEMORY_EMAIL=your-email@example.com
